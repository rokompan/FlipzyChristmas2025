{{ 'reward-system.css' | asset_url | stylesheet_tag }}
<script src="{{ 'reward-system.js' | asset_url }}" defer="defer"></script>

<section class="flipzy-rewards" id="FlipzyRewardSystem-{{ section.id }}" data-flipzy-reward-system>
  <script type="application/json" data-flipzy-reward-assets>
    {
      "castle": {
        "background": {{ 'reward-system-theme-castle-background.jpg' | asset_url | json }},
        "mainRewardGift": {{ 'reward-system-theme-castle-reward.png' | asset_url | json }},
        "miniRewardGift": {{ 'reward-system-theme-castle-mini-reward.png' | asset_url | json }},
        "sticker": {{ 'reward-system-theme-castle-sticker.png' | asset_url | json }},
        "pathTexture": {{ 'reward-system-theme-castle-path-texture.png' | asset_url | json }}
      },
      "princess": {
        "background": {{ 'reward-system-theme-princess-background.jpg' | asset_url | json }},
        "mainRewardGift": {{ 'reward-system-theme-princess-reward.png' | asset_url | json }},
        "miniRewardGift": {{ 'reward-system-theme-princess-mini-reward.png' | asset_url | json }},
        "sticker": {{ 'reward-system-theme-princess-sticker.png' | asset_url | json }},
        "pathTexture": {{ 'reward-system-theme-princess-path-texture.png' | asset_url | json }}
      },
      "garden": {
        "background": {{ 'reward-system-theme-garden-background.jpg' | asset_url | json }},
        "mainRewardGift": {{ 'reward-system-theme-garden-reward.png' | asset_url | json }},
        "miniRewardGift": {{ 'reward-system-theme-garden-mini-reward.png' | asset_url | json }},
        "sticker": {{ 'reward-system-theme-garden-sticker.png' | asset_url | json }},
        "pathTexture": {{ 'reward-system-theme-garden-path-texture.png' | asset_url | json }}
      },
      "space": {
        "background": {{ 'reward-system-theme-space-background.jpg' | asset_url | json }},
        "mainRewardGift": {{ 'reward-system-theme-space-reward.png' | asset_url | json }},
        "miniRewardGift": {{ 'reward-system-theme-space-mini-reward.png' | asset_url | json }},
        "sticker": {{ 'reward-system-theme-space-sticker.png' | asset_url | json }},
        "pathTexture": {{ 'reward-system-theme-space-path-texture.png' | asset_url | json }}
      },
      "ocean": {
        "background": {{ 'reward-system-theme-ocean-background.jpg' | asset_url | json }},
        "mainRewardGift": {{ 'reward-system-theme-ocean-reward.png' | asset_url | json }},
        "miniRewardGift": {{ 'reward-system-theme-ocean-mini-reward.png' | asset_url | json }},
        "sticker": {{ 'reward-system-theme-ocean-sticker.png' | asset_url | json }},
        "pathTexture": {{ 'reward-system-theme-ocean-path-texture.png' | asset_url | json }}
      },
      "candy": {
        "background": {{ 'reward-system-theme-candy-background.jpg' | asset_url | json }},
        "mainRewardGift": {{ 'reward-system-theme-candy-reward.png' | asset_url | json }},
        "miniRewardGift": {{ 'reward-system-theme-candy-mini-reward.png' | asset_url | json }},
        "sticker": {{ 'reward-system-theme-candy-sticker.png' | asset_url | json }},
        "pathTexture": {{ 'reward-system-theme-candy-path-texture.png' | asset_url | json }}
      },
      "dino": {
        "background": {{ 'reward-system-theme-dino-background.jpg' | asset_url | json }},
        "mainRewardGift": {{ 'reward-system-theme-dino-reward.png' | asset_url | json }},
        "miniRewardGift": {{ 'reward-system-theme-dino-mini-reward.png' | asset_url | json }},
        "sticker": {{ 'reward-system-theme-dino-sticker.png' | asset_url | json }},
        "pathTexture": {{ 'reward-system-theme-dino-path-texture.png' | asset_url | json }}
      }
    }
  </script>

  <script type="application/json" data-flipzy-reward-copy>
    {
      "defaults": {
        "childName": {{ 'sections.reward_system.defaults.child_name' | t | json }},
        "title": {{ 'sections.reward_system.defaults.title' | t: child: '[[child]]' | json }},
        "subtitle": {{ 'sections.reward_system.defaults.subtitle' | t | json }},
        "startLabel": {{ 'sections.reward_system.defaults.start_label' | t | json }},
        "rewardLabel": {{ 'sections.reward_system.defaults.reward_label' | t | json }}
      },
      "themes": {
        "castle": {{ 'sections.reward_system.themes.castle' | t | json }},
        "princess": {{ 'sections.reward_system.themes.princess' | t | json }},
        "garden": {{ 'sections.reward_system.themes.garden' | t | json }},
        "space": {{ 'sections.reward_system.themes.space' | t | json }},
        "ocean": {{ 'sections.reward_system.themes.ocean' | t | json }},
        "candy": {{ 'sections.reward_system.themes.candy' | t | json }},
        "dino": {{ 'sections.reward_system.themes.dino' | t | json }}
      },
      "status": {
        "saved": {{ 'sections.reward_system.status.saved' | t | json }},
        "saving": {{ 'sections.reward_system.status.saving' | t | json }},
        "storageFull": {{ 'sections.reward_system.status.storage_full' | t | json }},
        "preparingPrint": {{ 'sections.reward_system.status.preparing_print' | t | json }},
        "printReady": {{ 'sections.reward_system.status.print_ready' | t | json }},
        "printFailed": {{ 'sections.reward_system.status.print_failed' | t | json }}
      },
      "controls": {
        "mainRewardStep": {{ 'sections.reward_system.controls.main_reward_step' | t | json }}
      },
      "poster": {
        "posterAria": {{ 'sections.reward_system.poster.poster_aria' | t | json }},
        "fallbackTitle": {{ 'sections.reward_system.poster.fallback_title' | t | json }},
        "forChild": {{ 'sections.reward_system.poster.for_child' | t: child: '[[child]]' | json }},
        "miniReward": {{ 'sections.reward_system.poster.mini_reward' | t | json }},
        "stickerDefaultName": {{ 'sections.reward_system.poster.sticker_default_name' | t | json }},
        "stickersTitle": {{ 'sections.reward_system.poster.stickers_title' | t: child: '[[child]]' | json }},
        "stickerSubtitle": {{ 'sections.reward_system.poster.sticker_subtitle' | t | json }}
      },
      "print": {
        "frameTitle": {{ 'sections.reward_system.print.frame_title' | t | json }},
        "documentTitle": {{ 'sections.reward_system.print.document_title' | t | json }}
      }
    }
  </script>

  <div class="flipzy-rewards__shell">
    <aside class="flipzy-rewards__controls" aria-label="{{ 'sections.reward_system.ui.controls_aria' | t }}">
      <div class="flipzy-rewards__masthead">
        <h1>{{ 'sections.reward_system.ui.heading' | t }}</h1>
      </div>

      <fieldset class="flipzy-rewards__group">
        <legend>{{ 'sections.reward_system.ui.poster_text' | t }}</legend>
        <label class="flipzy-rewards__field">
          <span>{{ 'sections.reward_system.ui.child_name' | t }}</span>
          <input data-flipzy-control="childName" type="text" autocomplete="name">
        </label>
        <label class="flipzy-rewards__field">
          <span>{{ 'sections.reward_system.ui.title' | t }}</span>
          <input data-flipzy-control="title" type="text">
        </label>
        <label class="flipzy-rewards__field">
          <span>{{ 'sections.reward_system.ui.agreement' | t }}</span>
          <textarea data-flipzy-control="subtitle" rows="3"></textarea>
        </label>
        <div class="flipzy-rewards__field-grid">
          <label class="flipzy-rewards__field">
            <span>{{ 'sections.reward_system.ui.start_label' | t }}</span>
            <input data-flipzy-control="startLabel" type="text">
          </label>
          <label class="flipzy-rewards__field">
            <span>{{ 'sections.reward_system.ui.reward_label' | t }}</span>
            <input data-flipzy-control="rewardLabel" type="text">
          </label>
        </div>
      </fieldset>

      <fieldset class="flipzy-rewards__group">
        <legend>{{ 'sections.reward_system.ui.path' | t }}</legend>
        <div class="flipzy-rewards__step-control">
          <label class="flipzy-rewards__field">
            <span>{{ 'sections.reward_system.ui.steps' | t }}</span>
            <input data-flipzy-control="stepCount" type="range" min="1" max="50" step="1">
          </label>
          <label class="flipzy-rewards__field">
            <span>{{ 'sections.reward_system.ui.count' | t }}</span>
            <input data-flipzy-control="stepCount" type="number" min="1" max="50" step="1" inputmode="numeric">
          </label>
        </div>
        <div class="flipzy-rewards__checks">
          <label>
            <input data-flipzy-control="showNumbers" type="checkbox">
            <span>{{ 'sections.reward_system.ui.show_numbers' | t }}</span>
          </label>
          <label>
            <input data-flipzy-control="showMiniLabels" type="checkbox">
            <span>{{ 'sections.reward_system.ui.show_mini_reward_labels' | t }}</span>
          </label>
        </div>
      </fieldset>

      <fieldset class="flipzy-rewards__group">
        <legend>{{ 'sections.reward_system.ui.theme' | t }}</legend>
        <div class="flipzy-rewards__theme-buttons" data-flipzy-theme-buttons aria-label="{{ 'sections.reward_system.ui.style' | t }}"></div>
      </fieldset>

      <fieldset class="flipzy-rewards__group">
        <legend>{{ 'sections.reward_system.ui.mini_rewards' | t }}</legend>
        <div class="flipzy-rewards__presets" aria-label="{{ 'sections.reward_system.ui.mini_reward_presets_aria' | t }}">
          <button type="button" data-flipzy-mini-preset="half">{{ 'sections.reward_system.presets.half' | t }}</button>
          <button type="button" data-flipzy-mini-preset="thirds">{{ 'sections.reward_system.presets.thirds' | t }}</button>
          <button type="button" data-flipzy-mini-preset="quarters">{{ 'sections.reward_system.presets.quarters' | t }}</button>
          <button type="button" data-flipzy-mini-preset="every3">{{ 'sections.reward_system.presets.every_3' | t }}</button>
          <button type="button" data-flipzy-mini-preset="every5">{{ 'sections.reward_system.presets.every_5' | t }}</button>
          <button type="button" data-flipzy-mini-preset="clear">{{ 'sections.reward_system.presets.clear' | t }}</button>
        </div>
        <div class="flipzy-rewards__step-picker" data-flipzy-mini-step-picker aria-label="{{ 'sections.reward_system.ui.mini_reward_step_selection_aria' | t }}"></div>
      </fieldset>

    </aside>

    <main class="flipzy-rewards__preview" aria-label="{{ 'sections.reward_system.ui.preview_aria' | t }}">
      <div class="flipzy-rewards__toolbar">
        <span data-flipzy-save-status>{{ 'sections.reward_system.status.saved' | t }}</span>
        <div>
          <button type="button" class="flipzy-rewards__secondary" data-flipzy-reset>{{ 'sections.reward_system.ui.restore_defaults' | t }}</button>
          <button type="button" class="flipzy-rewards__primary" data-flipzy-print>{{ 'sections.reward_system.ui.print_poster_stickers' | t }}</button>
        </div>
      </div>
      <div class="flipzy-rewards__poster-frame" data-flipzy-poster-frame>
        <div class="flipzy-rewards__poster" data-flipzy-poster></div>
      </div>
    </main>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.reward_system.name",
  "tag": "section",
  "class": "section section-reward-system",
  "settings": [],
  "presets": [
    {
      "name": "t:sections.reward_system.presets.name"
    }
  ]
}
{% endschema %}
